<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:columnCount="3"
    android:rowCount="5"
    android:padding="8dp"
    tools:context=".fragment.KeyboardFragment">

    <!-- Row 1: 7, 8, 9 -->
    <Button
        android:id="@+id/btn7"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="7" />

    <Button
        android:id="@+id/btn8"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="8" />

    <Button
        android:id="@+id/btn9"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="9" />

    <!-- Row 2: 4, 5, 6 -->
    <Button
        android:id="@+id/btn4"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="4" />

    <Button
        android:id="@+id/btn5"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="5" />

    <Button
        android:id="@+id/btn6"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="6" />

    <!-- Row 3: 1, 2, 3 -->
    <Button
        android:id="@+id/btn1"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="1" />

    <Button
        android:id="@+id/btn2"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="2" />

    <Button
        android:id="@+id/btn3"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="3" />

    <!-- Row 4: ., 0, Delete -->
    <Button
        android:id="@+id/btnDot"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="." />

    <Button
        android:id="@+id/btn0"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="0" />

    <Button
        android:id="@+id/btnBackspace"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="DEL" />

    <!-- Row 5: Clear (spans 3 columns) -->
    <Button
        android:id="@+id/btnClear"
        style="@style/KeyboardButtonStyle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_columnSpan="3"
        android:layout_columnWeight="1"
        android:layout_rowWeight="1"
        android:layout_margin="4dp"
        android:text="C" />

</GridLayout>
