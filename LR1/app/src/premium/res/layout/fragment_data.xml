<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".fragment.DataFragment">

    <!-- Category Spinner -->
    <Spinner
        android:id="@+id/spinnerCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:spinnerMode="dropdown" />

    <!-- From section container -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@drawable/border_default">

        <!-- From unit section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/labelFrom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_from"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/content_desc_from_label"
                android:importantForAccessibility="yes" />

            <Spinner
                android:id="@+id/spinnerFromUnit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <!-- Input value with copy button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="end"
                android:hint="0"
                android:inputType="numberDecimal"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:cursorVisible="false"
                android:background="@android:color/transparent"
                android:backgroundTint="@android:color/transparent"
                android:padding="12dp"
                android:importantForAccessibility="yes"
                android:contentDescription="@string/content_desc_input_field" />

            <ImageButton
                android:id="@+id/btnCopyInput"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_save"
                android:contentDescription="@string/content_desc_copy_input"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:importantForAccessibility="yes" />
        </LinearLayout>
    </LinearLayout>

    <!-- Swap button -->
    <Button
        android:id="@+id/btnSwap"
        style="@style/KeyboardButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:text="@string/btn_swap"
        android:textSize="14sp"
        android:contentDescription="@string/content_desc_swap_button"
        android:importantForAccessibility="yes" />

    <!-- To section container -->
    <LinearLayout
        android:id="@+id/outputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@drawable/border_default">

        <!-- To unit section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/labelTo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_to"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/content_desc_to_label"
                android:importantForAccessibility="yes" />

            <Spinner
                android:id="@+id/spinnerToUnit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <!-- Output value with copy button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etOutput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="end"
                android:hint="0"
                android:inputType="numberDecimal"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:cursorVisible="false"
                android:background="@android:color/transparent"
                android:backgroundTint="@android:color/transparent"
                android:padding="12dp"
                android:textColor="#5c8d8e"
                android:importantForAccessibility="yes"
                android:contentDescription="@string/content_desc_output_field" />

            <ImageButton
                android:id="@+id/btnCopyOutput"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_save"
                android:contentDescription="@string/content_desc_copy_output"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:importantForAccessibility="yes" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
